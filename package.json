{
  "name": "runwayctrl",
  "version": "0.1.0",
  "private": true,
  "description": "Agent execution control plane — effectively-once delivery, governed retries, bounded concurrency, and explainable runs.",
  "license": "Apache-2.0",
  "author": "RunwayCtrl Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/RunwayCtrl/RunwayCtrl.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "echo 'dev server not yet configured'",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "echo 'migrations not yet configured'",
    "db:seed": "echo 'seed not yet configured'"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  }
}
