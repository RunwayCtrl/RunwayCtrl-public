{
  "name": "runwayctrl",
  "version": "0.1.1",
  "private": true,
  "description": "Agent execution control plane — effectively-once delivery, governed retries, bounded concurrency, and explainable runs.",
  "license": "Apache-2.0",
  "author": "RunwayCtrl Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/RunwayCtrl/RunwayCtrl.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "changeset": "changeset",
    "changeset:status": "changeset status --since main",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "dev": "pnpm --filter @runwayctrl/control-plane dev",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "commitlint": "commitlint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.unit.config.ts",
    "db:migrate": "pnpm --filter @runwayctrl/control-plane db:migrate",
    "db:seed": "pnpm --filter @runwayctrl/control-plane db:seed"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.0",
    "turbo": "^2.8.12",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
