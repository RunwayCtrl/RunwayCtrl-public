# ─────────────────────────────────────────────────────────────
# RunwayCtrl — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=8080
API_HOST=0.0.0.0

# ── Database (Postgres 16+) ─────────────────────────────────
DATABASE_URL=postgresql://runwayctrl:runwayctrl@localhost:5432/runwayctrl

# ── Redis (optional — used for lease caching) ───────────────
# REDIS_URL=redis://localhost:6379

# ── RunwayCtrl API Key ──────────────────────────────────────
# Used by tenants to authenticate against the control plane
# Format: <api_key_id>.<api_key_secret>
# Example: key_abcd1234deadbeef.my-secret
RUNWAYCTRL_API_KEY=key_dev_change_me.my_secret_change_me

# ── Jira Cloud ──────────────────────────────────────────────
# Signup: https://developer.atlassian.com/console/myapps/
# API Token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# ── ServiceNow ──────────────────────────────────────────────
# Signup: https://developer.servicenow.com/ (Personal Developer Instance)
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=

# ── GitHub ──────────────────────────────────────────────────
# Personal Access Token with repo + workflow scopes
GITHUB_TOKEN=

# ── OpenTelemetry ───────────────────────────────────────────
# Explicit toggle. If unset, telemetry auto-enables when an exporter endpoint is configured.
# RUNWAYCTRL_OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Optional: comma-separated "k=v" pairs (e.g. "Authorization=Bearer xxx")
# OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=runwayctrl
# Optional service metadata
DEPLOYMENT_ENVIRONMENT=development
# CLOUD_REGION=us-west-2

# ── Dashboard / Console ─────────────────────────────────────
# Template for deep-linking trace IDs in the dashboard
# Use {traceId} as the placeholder
RUNWAYCTRL_TRACE_URL_TEMPLATE=http://localhost:16686/trace/{traceId}

# ── The Hub (LLM Execution Analysis) ────────────────────────
# Provider-configurable LLM analysis of execution patterns.
# Disabled by default; enable after sufficient ledger data.
ENABLE_HUB=false
RUNWAYCTRL_HUB_PROVIDER=openai
RUNWAYCTRL_HUB_MODEL=gpt-5.2
RUNWAYCTRL_HUB_API_KEY=
RUNWAYCTRL_HUB_MIN_DATA_DAYS=7

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
# Structured JSON logs in production, pretty in development
LOG_FORMAT=pretty
